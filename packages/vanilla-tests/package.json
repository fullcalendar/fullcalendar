{
  "private": true,
  "name": "@fullcalendar-tests/standard",
  "version": "0.0.0",
  "dependencies": {
    "luxon": "^2.0.0",
    "moment": "^2.29.1",
    "moment-timezone": "^0.5.40",
    "preact": "^10.29.0",
    "xhr-mock": "^2.5.1"
  },
  "devDependencies": {
    "@fullcalendar-scripts/standard": "workspace:*",
    "@fullcalendar/format-luxon3": "workspace:*",
    "@fullcalendar/format-moment": "workspace:*",
    "@fullcalendar/google-calendar": "workspace:*",
    "@fullcalendar/icalendar": "workspace:*",
    "@fullcalendar/rrule": "workspace:*",
    "@types/jasmine": "^3.3.12",
    "@types/jasmine-jquery": "^1.5.33",
    "@types/jquery": "^3.3.29",
    "fetch-mock": "^9.11.0",
    "fullcalendar": "workspace:*",
    "fullcalendar-w-react": "workspace:*",
    "handlebars": "^4.7.7",
    "retry-cli": "^0.7.0",
    "temporal-polyfill": "^0.3.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "test": "standard-scripts pkg:test",
    "test:dev": "retry -n 999 -- standard-scripts pkg:test --dev",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": "./build.config.js",
  "karmaConfig": {
    "suites": {
      "default": {
        "files": [
          "./dist/index.js"
        ]
      },
      "global:locale": {
        "files": [
          "./node_modules/fullcalendar/all.global.js",
          "./node_modules/fullcalendar/locales/ar.global.js",
          "./src/global-locale.js"
        ]
      },
      "global:locales-all": {
        "files": [
          "./node_modules/fullcalendar/all.global.js",
          "./node_modules/fullcalendar/locales-all.global.js",
          "./src/global-locales-all.js"
        ]
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    "./scripts/*": "./scripts/*.js",
    "./lib/*": {
      "types": "./dist/.tsout/lib/*.d.ts",
      "default": "./dist/.tsout/lib/*.js"
    },
    ".": {
      "types": "./dist/.tsout/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": [
    "./dist/.tsout/lib/global.js",
    "./dist/.tsout/lib/global-utils.js",
    "./dist/.tsout/lib/global-plugins.js"
  ]
}
