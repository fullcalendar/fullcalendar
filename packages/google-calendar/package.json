{
  "name": "@fullcalendar/google-calendar",
  "version": "7.0.0-rc.3",
  "title": "FullCalendar Google Calendar Plugin",
  "description": "Display events from a public Google Calendar feed",
  "homepage": "https://fullcalendar.io/docs/google-calendar",
  "keywords": [
    "google-calendar"
  ],
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-rc.3",
    "@fullcalendar/core": "workspace:7.0.0-rc.3"
  },
  "peerDependencies": {
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@fullcalendar-scripts/standard": "workspace:*",
    "temporal-polyfill": "^0.3.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "globalConfig": {
    },
    "exports": {
      ".": {
        "format": "module"
      },
      "./global": {
        "format": "global",
        "primary": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}
