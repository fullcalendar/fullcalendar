{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "lib": [
      "es2021",
      "dom"
    ],
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "strictBindCallApply": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": [],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "allowSyntheticDefaultImports": true
  }
}
